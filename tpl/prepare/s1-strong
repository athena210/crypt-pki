# Strong server template

verb                    1
persist-tun
dev-type                tun
dev                     vpn1
proto                   tcp4-server
port                    $PREPARE_TEMPLATE_PORT1
data-ciphers-fallback   AES-256-CBC
auth                    SHA256
data-ciphers            AES-256-GCM:AES-256-CBC
tls-version-min         1.3
dh                      none
remote-cert-tls         client
server                  {{ OVPN_STRONG_NET4 | get_network }} {{ OVPN_STRONG_NET4 | get_netmask }}

{% if OVPN_STRONG_NET6 is defined %}
server-ipv6             {{ OVPN_STRONG_NET6 }}
{% endif %}

topology                subnet
keepalive               10  23

setenv                  instance    strong
script-security         2
auth-user-pass-verify   "/usr/bin/env python3 /etc/vpn/helper.py" via-file
client-connect          "/usr/bin/env python3 /etc/vpn/helper.py"
learn-address           "/usr/bin/env python3 /etc/vpn/helper.py"

ca                      /pki/ca.crt
crl-verify              /pki/crl.pem
cert                    /pki/server.crt
key                     /pki/server.key
tls-crypt-v2            /pki/server.tc2 force-cookie

management              127.0.0.1 5555
