        ret=0
        exec_inside "$crypto_dir" "easy-rsa/easyrsa export-p7 $internalname" || ret=1
        if \
            [ "$ret" -eq 0 ] && \
            ! mv -f "$crypto_dir/pki/issued/${internalname}.p7b" "$export_file"
        then
            ret=1
        fi
        close_container "$pki_container" || ret=1

        exit "$ret"
    ;;

    "--export-zip")
        if ! internalname="$(getparam "--internalname" "$@")" || [ "$internalname" == "ca" ] ; then
            errorinfo 'Incorrect internalname. Can not be empty or "ca"'
            exit 1
        fi

        if ! export_file="$(getparam "--file" "$@")" ; then
            errorinfo "Where to export?"
            exit 1
        fi
        export_file="$(realpath -ms -- "$export_file")"
        mkdir -p "$(dirname "$export_file")" || exit 1

        close_container "$pki_container" || exit 1
        crypto_dir="$(open_container "$pki_container" "$CTKEY")" || exit 1

        serverkey="$(getparam "--servertc2" "$@")"
        key_file="$crypto_dir/tls-crypt-v2/"
        server_key_file=""
        if [ -n "$serverkey" ] ; then
            key_file="${key_file}${serverkey}___"
            server_key_file="$crypto_dir/tls-crypt-v2/${serverkey}.tc2"
        fi
        key_file="${key_file}${internalname}.tc2"
        [ -f "$key_file" ] || key_file=""

        crl_file="$crypto_dir/pki/crl.pem"
        [ -f "$crl_file" ] || crl_file=""

        ret=0
        if [ -f "$export_file" ] ; then
            rm -f "$export_file" || ret=1
        fi

        zip -j "$export_file" "$crl_file" "$crypto_dir/pki/ca.crt" "$key_file" "$crypto_dir/pki/issued/${internalname}.crt" "$crypto_dir/pki/private/${internalname}.key" || ret=1
        close_container "$pki_container" || ret=1

        exit "$ret"
    ;;

    "--export-config")
        if \
            ! internalname="$(getparam "--internalname" "$@")" || \
            [ "$internalname" == "ca" ]
        then
            errorinfo 'Incorrect internalname. Can not be empty or "ca"'
            exit 1
        fi

        if ! export_file="$(getparam "--file" "$@")" ; then
            errorinfo "Where to export?"
            exit 1
        fi
        export_file="$(realpath -ms -- "$export_file")"
        if \
            ! mkdir -p "$(dirname "$export_file")" || \
            ! touch "$export_file" || \
            [ ! -w "$export_file" ] || \
            [ ! -f "$export_file" ]
        then
            errorinfo "Cannot write in file: $export_file"
            exit 1
        fi

        if ! template="$(getparam "--template" "$@")" ; then
            errorinfo "Need a template"
            exit 1
        fi

        close_container "$pki_container" || exit 1
        crypto_dir="$(open_container "$pki_container" "$CTKEY")" || exit 1

        serverkey="$(getparam "--servertc2" "$@")"
        key_file="$crypto_dir/tls-crypt-v2/"
        server_key_file=""
        if [ -n "$serverkey" ] ; then
            key_file="${key_file}${serverkey}___"
            server_key_file="$crypto_dir/tls-crypt-v2/${serverkey}.tc2"
        fi
        key_file="${key_file}${internalname}.tc2"

        ret=0
        if \
            [ "$ret" -eq 0 ] && \
            [ ! -f "$crypto_dir/pki/issued/${internalname}.crt" ]
        then
            ret=1
            errorinfo "No cert with this internalname: $internalname"
        fi

        if \
            [ "$ret" -eq 0 ] && \
            [ ! -f "$crypto_dir/templates/$template" ]
        then
            ret=1
            errorinfo "No such template: $template"
        fi

        if [ "$ret" -eq 0 ]; then
            (
                SUBSTKEYNAME="$internalname"
                SUBSTCA="$(echo -e "<ca>\n$(cat "$crypto_dir/pki/ca.crt")\n</ca>")"
                SUBSTCERT="$(echo -e "<cert>\n$(cat "$crypto_dir/pki/issued/${internalname}.crt")\n</cert>")"
                if [ -f "$key_file" ]; then
                    SUBSTTC2="$(echo -e "<tls-crypt-v2>\n$(cat "$key_file")\n</tls-crypt-v2>")"
                    export SUBSTTC2
                fi
                fingerprint="$(openssl x509 -in "$crypto_dir/pki/issued/${internalname}.crt" -fingerprint -noout | sed 's/://g' | cut -d"=" -f2)"
                # trunk-ignore(shellcheck/SC2089)
                SUBSTCERTAPI="cryptoapicert \"THUMB:${fingerprint}\""
                export SUBSTKEYNAME
                export SUBSTCA
                export SUBSTCERT
                # trunk-ignore(shellcheck/SC2090)
                export SUBSTCERTAPI
                if [ -f "$crypto_dir/pki/private/${internalname}.key" ] ; then
                    SUBSTKEY="$(echo -e "<key>\n$(cat "$crypto_dir/pki/private/${internalname}.key")\n</key>")"
                    export SUBSTKEY
                fi
                envsubst < "$crypto_dir/templates/$template" > "$export_file"
            ) || ret=1
        fi
        close_container "$pki_container" || ret=1

        exit "$ret"
    ;;

    *)
        errorinfo "No command given"
        exit 1
        ;;
esac
